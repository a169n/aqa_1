{
  "name": "server",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "node scripts/dev.cjs",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint --fix \"src/**/*.ts\"",
    "test": "vitest",
    "test:coverage": "vitest run --coverage --reporter=default --reporter=json --outputFile.json=../.tmp/qa/vitest-report.json",
    "db:reset:test": "tsx src/test/reset-db.ts",
    "db:clean": "tsx src/scripts/clean-db.ts",
    "db:seed": "tsx src/scripts/seed-db.ts",
    "qa:summary": "tsx src/qa/generate-qa-summary.ts",
    "qa:gates": "npm run qa:summary && tsx src/qa/check-quality-gates.ts",
    "typeorm": "typeorm-ts-node-commonjs -d src/config/data-source.ts",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "perf:smoke": "cross-env PERF_PROFILE=smoke tsx src/experimental/performance/run-performance.ts",
    "perf:full": "cross-env PERF_PROFILE=full tsx src/experimental/performance/run-performance.ts",
    "perf:summary": "tsx src/experimental/performance/summarize-performance.ts",
    "mutation:test": "tsx src/experimental/mutation/run-mutation.ts",
    "mutation:summary": "tsx src/experimental/mutation/summarize-mutation.ts",
    "chaos:run": "tsx src/experimental/chaos/run-chaos.ts",
    "chaos:inject": "tsx src/experimental/chaos/chaos-action.ts",
    "chaos:restore": "tsx src/experimental/chaos/chaos-action.ts",
    "experimental:summary": "tsx src/experimental/generate-experimental-summary.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.3",
    "reflect-metadata": "^0.2.2",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.21"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.14",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "cross-env": "^10.1.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.3",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^5.8.2",
    "vitest": "^4.1.0"
  }
}
