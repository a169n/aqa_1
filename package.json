{
  "name": "inkwell-platform",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace server\" \"npm run dev --workspace client\"",
    "dev:server": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "db:clean": "npm run db:clean --workspace server",
    "db:seed": "npm run db:seed --workspace server",
    "db:reset:test": "npm run db:reset:test --workspace server",
    "start:test:server": "npm run db:reset:test && npm run build --workspace server && npm run start --workspace server",
    "start:test:client": "npm run build --workspace client && npm run preview --workspace client -- --host 127.0.0.1 --strictPort --port 4173",
    "build": "npm run build --workspace server && npm run build --workspace client",
    "lint": "npm run lint --workspace server && npm run lint --workspace client",
    "lint:fix": "npm run lint:fix --workspace server && npm run lint:fix --workspace client",
    "test:api": "npm run test --workspace server -- --run",
    "test:coverage": "npm run test:coverage --workspace server",
    "test:e2e": "playwright test",
    "test": "npm run test:api && npm run test:e2e",
    "qa:summary": "npm run qa:summary --workspace server",
    "qa:gates": "npm run qa:gates --workspace server",
    "ci": "npm run lint && npm run build && npm run test:coverage && npm run test:e2e && npm run qa:gates",
    "docker:build:backend": "docker build -f server/Dockerfile .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "perf:smoke": "npm run perf:smoke --workspace server",
    "perf:full": "npm run perf:full --workspace server",
    "perf:summary": "npm run perf:summary --workspace server",
    "mutation:test": "npm run mutation:test --workspace server",
    "mutation:summary": "npm run mutation:summary --workspace server",
    "chaos:run": "npm run chaos:run --workspace server",
    "chaos:inject": "npm run chaos:inject --workspace server",
    "chaos:restore": "npm run chaos:restore --workspace server",
    "experimental:summary": "npm run experimental:summary --workspace server"
  },
  "overrides": {
    "brace-expansion": "2.0.3",
    "vite": "6.4.2",
    "express": {
      "path-to-regexp": "0.1.13"
    },
    "glob": {
      "brace-expansion": "2.0.3"
    },
    "minimatch": {
      "brace-expansion": "2.0.3"
    },
    "path-to-regexp": "0.1.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.5.3"
  }
}
